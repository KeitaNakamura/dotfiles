#!/bin/bash

FREE=
USED=
TOTAL=

function calculate_memory() {
  # vm_stat
  #  page size of 4096 bytes
  local info=$(vm_stat)
  local pages_free=$(echo "$info" | awk '/Pages free:/ {print $3}' | tr -d '.')
  local pages_active=$(echo "$info" | awk '/Pages active:/ {print $3}' | tr -d '.')
  local pages_inactive=$(echo "$info" | awk '/Pages inactive:/ {print $3}' | tr -d '.')
  local pages_speculative=$(echo "$info" | awk '/Pages speculative:/ {print $3}' | tr -d '.')
  local pages_wired=$(echo "$info" | awk '/Pages wired down:/ {print $4}' | tr -d '.')

  FREE=$(($pages_free + $pages_speculative))
  USED=$(($pages_active + $pages_inactive + $pages_wired))
  TOTAL=$(($FREE + $USED))
}

function get_used_percentage() {
  echo "$(($USED * 1000 / $TOTAL))" | sed -e 's/\(.*\)\([0-9]\)/\1.\2/' -e 's/^\./0./'
}

calculate_memory
get_used_percentage
